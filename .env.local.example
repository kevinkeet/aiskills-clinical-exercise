# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Admin dashboard (read-only stats / CSV export)
ADMIN_PASSWORD=your-admin-password

# Coordinator-only seed endpoint (POST /api/admin/seed-participants).
# Generate with: openssl rand -hex 32
COORDINATOR_TOKEN=your-coordinator-token

# Server-side session signing (HTTP-only cookie HMAC).
# At least 16 chars; longer is better. Generate with: openssl rand -hex 32
SESSION_SECRET=your-session-secret

# Randomization seed for scripts/generate-randomization.ts.
# Pick once before recruitment opens and never change.
RANDOMIZATION_SEED=irb-86737-fixed-seed-do-not-change
